# ============================================================
# Sage X3 Connection
# ============================================================
X3_BASE_URL=http://your-x3-server:8124
X3_FOLDER=YourFolder
X3_USERNAME=admin
X3_PASSWORD=your-password

# ============================================================
# FIRS E-Invoicing API (Cryptware Systems)
# ============================================================
# Environment: test | prod
FIRS_ENV=test

# Swift Oil Limited (SWI03)
SWIFT_FIRS_TEST_KEY=sk_live_your_swift_test_key
SWIFT_FIRS_PROD_KEY=sk_live_your_swift_prod_key
SWIFT_SUPPLIER_TIN=00000000-0001
SWIFT_SUPPLIER_EMAIL=info@swiftoil.com
SWIFT_SUPPLIER_PHONE=+2348000000000

# Chorus Energy Limited (CHO01)
CHORUS_FIRS_TEST_KEY=sk_live_your_chorus_test_key
CHORUS_FIRS_PROD_KEY=sk_live_your_chorus_prod_key
CHORUS_SUPPLIER_TIN=00000000-0001
CHORUS_SUPPLIER_EMAIL=info@chorusenergy.com
CHORUS_SUPPLIER_PHONE=+2348000000000

# ============================================================
# Flask session secret (any random string)
# ============================================================
FLASK_SECRET_KEY=change-me-to-a-random-string
